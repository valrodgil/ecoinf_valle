mk <- raster.kendall(r8, method = "none")
mk <- raster.kendall(r12, method = "none")
plot(mk)
signif <- mk$`p-value` < 0.05
plot(signif)
plot(!signif)
mk_slope <- mk$slope
plot(mk_slope)
mk_slope[!signif]<-NA
plot(mk_slope)
table(as.vector(signif))
writeRaster(mk_slope, 'output_mk_slope_scale8_signif.tif', overwrite = T) # only significant slope values
writeRaster(mk$slope, 'output_mk_slope_scale8.tif', overwrite = T)
set.seed(666)
abundancia1<-sort(rnorm(200, mean=30, sd=1))
abundancia2<-rnorm(200, mean=10, sd=0.1)
factor1<-gl(2, 100, labels=c("Control", "Exp"))
Replica<-gl(4, 25, 200, labels = c("Rep1", "Rep2", "Rep3", "Rep4"))
dataset<-data.frame(abundancia1, abundancia2, factor1, Replica)
library(nlme)
mod.intercept<-lme(abundancia1~factor1, random=~1|Replica, data=dataset)
anova(mod.intercept)
summary (mod.intercept)
mod.interceptA<-lme(abundancia1~factor1, random=~factor 1|Replica, data=dataset)
mod.interceptA<-lme(abundancia1~factor1, random=~factor1|Replica, data=dataset)
anova(mod.intercept, mod.interceptA)
modeloS <- lm(abundancia1~factor1, data=dataset)
anova(mod.interceptA, modeloS)
library(lme4)
install.packages("lmerTest")
library(lmerTest)
lmer(abundancia1~factor1 + (1|Replica), data=dataset)
MODB<-lmer(abundancia1~factor1 + (factor1|Replica), data=dataset) #Con pendientes aleatorias
MODA<-lmer(abundancia1~factor1 + (1|Replica), data=dataset) #vamos a hacer lo mismo pero con esta otra función
anova(MODA, MODB)
ranova(MODB)
ranova(MODA)
